{
  "manifest_version": 3,
  "name": "Izuku Midoriya: Rising",
  "description": "Full Izuku Midoriya: Rising themed mod - animated wallpaper, You Say Run background music, sounds, Deku green theme, shaders, and webmodding for 21+ popular sites (YouTube, Twitter, Reddit, Discord, GitHub, Netflix, Spotify, and more) with matching accent colours across the web",
  "version": "1.2",
  "icons": {
    "512": "Deku_Nut.png"
  },
  "developer": {
    "name": "Humza Butt"
  },
  "mod": {
    "schema_version": 1,
    "license": "license.txt",
    "payload": {
      "wallpaper": {
        "dark": {
          "image": "wallpaper/dark.webm",
          "first_frame": "wallpaper/dark.png",
          "text_color": "#FFFFFF",
          "text_shadow": "#000000"
        },
        "light": {
          "image": "wallpaper/light.webm",
          "first_frame": "wallpaper/light.png",
          "text_color": "#000000",
          "text_shadow": "#FFFFFF"
        }
      },
      "background_music": [
        "music/You_Say_Run_Track_1.wav",
        "music/You_Say_Run_Track_2.wav",
        "music/You_Say_Run_Track_3.wav",
        "music/You_Say_Run_Track_4.wav"
      ],
      "browser_sounds": {
        "CLICK": ["sound/click.wav"],
        "FEATURE_SWITCH_OFF": ["sound/feature_switch_off.wav"],
        "FEATURE_SWITCH_ON": ["sound/feature_switch_on.wav"],
        "HOVER": ["sound/hover.wav"],
        "HOVER_UP": ["sound/hover.wav"],
        "IMPORTANT_CLICK": ["sound/important_click.wav"],
        "LEVEL_UPGRADE": ["sound/level_upgrade.wav"],
        "LIMITER_OFF": ["sound/limiter_off.wav"],
        "LIMITER_ON": ["sound/limiter_on.wav"],
        "SWITCH_TOGGLE": ["sound/switch.wav"],
        "TAB_CLOSE": ["sound/close_tab.wav"],
        "TAB_INSERT": ["sound/new_tab.wav"],
        "TAB_SLASH": ["sound/tab_slash.wav"]
      },
      "keyboard_sounds": {
        "TYPING_BACKSPACE": ["keyboard/backspace.wav"],
        "TYPING_ENTER": ["keyboard/enter.wav"],
        "TYPING_LETTER": ["keyboard/letter_1.wav", "keyboard/letter_2.wav", "keyboard/letter_3.wav"],
        "TYPING_SPACE": ["keyboard/space.wav"]
      },
      "theme": {
        "dark": {
          "gx_accent": { "h": 145, "s": 85, "l": 50 },
          "gx_secondary_base": { "h": 220, "s": 60, "l": 12 }
        },
        "light": {
          "gx_accent": { "h": 145, "s": 80, "l": 40 },
          "gx_secondary_base": { "h": 220, "s": 40, "l": 92 }
        }
      },
      "shaders": {
        "Hero Glow": {
          "path": "shader/hero_glow.txt"
        },
        "Plus Ultra": {
          "animation": { "duration": 60, "steps": 3600 },
          "path": "shader/plus_ultra.txt"
        }
      },
      "page_styles": [
        {
          "css": ["webmodding/deku-rising.css"],
          "matches": ["https://*/*", "http://*/*"]
        },
        {
          "css": ["webmodding/sites-01-google-youtube.css"],
          "matches": [
            "https://www.google.com/*",
            "https://google.com/*",
            "https://mail.google.com/*",
            "https://drive.google.com/*",
            "https://docs.google.com/*",
            "https://calendar.google.com/*",
            "https://maps.google.com/*",
            "https://news.google.com/*",
            "https://play.google.com/*",
            "https://accounts.google.com/*",
            "https://photos.google.com/*",
            "https://meet.google.com/*",
            "https://classroom.google.com/*",
            "https://keep.google.com/*",
            "https://translate.google.com/*",
            "https://contacts.google.com/*",
            "https://www.youtube.com/*",
            "https://youtube.com/*",
            "https://m.youtube.com/*",
            "https://music.youtube.com/*"
          ]
        },
        {
          "css": ["webmodding/sites-02-social.css"],
          "matches": [
            "https://www.reddit.com/*",
            "https://reddit.com/*",
            "https://old.reddit.com/*",
            "https://new.reddit.com/*",
            "https://www.x.com/*",
            "https://x.com/*",
            "https://twitter.com/*",
            "https://www.twitter.com/*",
            "https://mobile.twitter.com/*",
            "https://www.facebook.com/*",
            "https://facebook.com/*",
            "https://m.facebook.com/*",
            "https://web.facebook.com/*",
            "https://www.instagram.com/*",
            "https://instagram.com/*",
            "https://www.tiktok.com/*",
            "https://tiktok.com/*",
            "https://www.discord.com/*",
            "https://discord.com/*",
            "https://www.pinterest.com/*",
            "https://pinterest.com/*",
            "https://www.tumblr.com/*",
            "https://tumblr.com/*",
            "https://www.linkedin.com/*",
            "https://linkedin.com/*",
            "https://www.threads.net/*",
            "https://threads.net/*",
            "https://web.whatsapp.com/*",
            "https://*.fb.com/*",
            "https://*.messenger.com/*"
          ]
        },
        {
          "css": ["webmodding/sites-03-dev.css"],
          "matches": [
            "https://github.com/*",
            "https://gist.github.com/*",
            "https://gitlab.com/*",
            "https://stackoverflow.com/*",
            "https://*.stackexchange.com/*",
            "https://stackexchange.com/*",
            "https://superuser.com/*",
            "https://serverfault.com/*",
            "https://askubuntu.com/*",
            "https://math.stackexchange.com/*",
            "https://news.ycombinator.com/*"
          ]
        },
        {
          "css": ["webmodding/sites-04-shopping.css"],
          "matches": [
            "https://www.amazon.com/*",
            "https://amazon.com/*",
            "https://www.amazon.co.uk/*",
            "https://amazon.co.uk/*",
            "https://www.amazon.de/*",
            "https://amazon.de/*",
            "https://www.amazon.ca/*",
            "https://amazon.ca/*",
            "https://www.amazon.co.jp/*",
            "https://amazon.co.jp/*",
            "https://www.amazon.fr/*",
            "https://amazon.fr/*",
            "https://www.amazon.es/*",
            "https://amazon.es/*",
            "https://www.amazon.it/*",
            "https://amazon.it/*",
            "https://www.amazon.in/*",
            "https://amazon.in/*",
            "https://www.amazon.com.au/*",
            "https://amazon.com.au/*",
            "https://www.ebay.com/*",
            "https://ebay.com/*",
            "https://www.ebay.co.uk/*",
            "https://ebay.co.uk/*",
            "https://www.ebay.de/*",
            "https://ebay.de/*",
            "https://www.paypal.com/*",
            "https://paypal.com/*",
            "https://www.apple.com/*",
            "https://apple.com/*"
          ]
        },
        {
          "css": ["webmodding/sites-05-media.css"],
          "matches": [
            "https://www.netflix.com/*",
            "https://netflix.com/*",
            "https://open.spotify.com/*",
            "https://www.spotify.com/*",
            "https://spotify.com/*",
            "https://www.twitch.tv/*",
            "https://twitch.tv/*",
            "https://www.bbc.com/*",
            "https://bbc.com/*",
            "https://www.bbc.co.uk/*",
            "https://bbc.co.uk/*",
            "https://www.cnn.com/*",
            "https://cnn.com/*",
            "https://www.imdb.com/*",
            "https://imdb.com/*",
            "https://medium.com/*",
            "https://www.medium.com/*"
          ]
        },
        {
          "css": ["webmodding/sites-06-productivity.css"],
          "matches": [
            "https://*.wikipedia.org/*",
            "https://www.notion.so/*",
            "https://notion.so/*",
            "https://*.notion.site/*",
            "https://www.dropbox.com/*",
            "https://dropbox.com/*",
            "https://outlook.live.com/*",
            "https://www.office.com/*",
            "https://office.com/*",
            "https://www.microsoft.com/*",
            "https://microsoft.com/*",
            "https://login.live.com/*",
            "https://account.microsoft.com/*",
            "https://www.yahoo.com/*",
            "https://yahoo.com/*",
            "https://mail.yahoo.com/*",
            "https://news.yahoo.com/*",
            "https://store.steampowered.com/*",
            "https://steamcommunity.com/*",
            "https://help.steampowered.com/*",
            "https://*.craigslist.org/*",
            "https://www.indeed.com/*",
            "https://indeed.com/*"
          ]
        },
        {
          "css": ["webmodding/deku-opera.css"],
          "matches": ["https://*.opera.com/*"]
        }
      ]
    }
  }
}
